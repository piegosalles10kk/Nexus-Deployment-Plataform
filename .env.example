# ── NEXUS PLATFORM ENVIRONMENT VARIABLES ─────────────────────────────────────

# ── NODE ENVIRONMENT ─────────────────────────────────────────────────────────
NODE_ENV=production
# Main API Port (Backend)
PORT=4500

# ── DATABASE (PostgreSQL) ────────────────────────────────────────────────────
# Individual values used by docker-compose for the database container
POSTGRES_USER=nexus_admin
POSTGRES_PASSWORD=Inbox@2026
POSTGRES_DB=nexus_db

# Complete connection string used by Prisma/Backend
# Format: postgresql://USER:PASS@HOST:PORT/DB
# When using Docker Compose, use '10kk-postgres' as the host.
DATABASE_URL=postgresql://nexus_admin:Inbox@2026@10kk-postgres:5432/nexus_db

# ── CACHE & RATE LIMIT (Redis) ───────────────────────────────────────────────
# When using Docker Compose, use '10kk-redis' as the host.
REDIS_URL=redis://10kk-redis:6379

# ── SECURITY ─────────────────────────────────────────────────────────────────
# JWT Secret for session signing. Use a long random string.
JWT_SECRET=your_long_random_jwt_secret_here

# Encryption Key for sensitive secrets (AES-256-GCM).
# MUST be exactly 64 hex characters (32 bytes).
# Tip: openssl rand -hex 32
ENCRYPTION_KEY=e1357eaa3a1ca199d708b9580f0c40811316b1df6e55d5404248c3360cfb2713

# GitHub Webhook Secret (HMAC-SHA256). 
# Must match the "Secret" field in your GitHub Webhook settings.
GITHUB_WEBHOOK_SECRET=b613679a0814d9ec772f95d778c35fc5ff1697c493715653c6c712144292c5ad

# ── GEMINI AI ────────────────────────────────────────────────────────────────
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── NETWORKING ───────────────────────────────────────────────────────────────
# Frontend Public URL. 
# CRITICAL: This is used for CORS and Socket.io authentication.
# Example: https://piegosalles-backend.cloud
FRONTEND_URL=https://piegosalles-backend.cloud

# Agent WebSocket (mTLS) Port. Default is 8443.
AGENT_WS_PORT=8443

# Docker Proxy Host. 
# Used by backend to talk to Docker via the proxy container.
DOCKER_PROXY_HOST=tcp://10kk-docker-proxy:2375

# Port Check Host. 
# Use 'host.docker.internal' inside Docker to check ports on the host machine.
PORT_CHECK_HOST=host.docker.internal

# ── FRONTEND BUILD TIME VARIABLES ───────────────────────────────────────────
# Public API URL (including /api). 
# If using the integrated Nginx proxy, this is just your domain + /api.
VITE_API_URL=https://piegosalles-backend.cloud/api

# ── EMAIL SETTINGS (Optional) ────────────────────────────────────────────────
# For notifications or password resets.
EMAIL_USER=
EMAIL_PASS=
